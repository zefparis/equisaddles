{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist/server",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": [
      "./shared",
      "./node_modules/@types"
    ],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["./shared/*"]
    },
    "resolveJsonModule": true,
    "noEmit": false,
    "emitDeclarationOnly": false
  },
  "include": ["server/**/*.ts", "shared/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
