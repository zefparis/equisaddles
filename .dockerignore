# Ignore everything by default
**

# Allow these files and directories
!package.json
!package-lock.json
!tsconfig*.json
!nixpacks.toml
!Dockerfile

# Allow server and shared source directories
!server/
!shared/
!client/

# But ignore specific patterns within those directories
**/node_modules
**/dist
**/.git
**/.gitignore
**/.DS_Store
**/.env
**/.env.*
**/npm-debug.log
**/yarn-debug.log
**/yarn-error.log
**/.next
**/out
**/build
**/.cache
**/.vscode
**/.idea
**/coverage
**/*.md
**/*.log
